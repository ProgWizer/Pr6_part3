<Page x:Class="pr14.Pages.General"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="550" d:DesignWidth="900"
      Title="General">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#F5F5F5" BorderBrush="#E0E0E0" BorderThickness="1" Padding="16" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Сортировка:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="cmbSort" Width="150" Height="28" Margin="0,0,20,0" SelectionChanged="cmbSort_SelectionChanged">
                        <ComboBoxItem Content="По умолчанию" Tag="None" IsSelected="True"/>
                        <ComboBoxItem Content="По названию" x:Name="sortByName"/>
                        <ComboBoxItem Content="По рейтингу" x:Name="sortByRate"/>
                    </ComboBox>

                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="nameInput" Width="180" Height="28" VerticalContentAlignment="Center" TextChanged="nameInput_TextChanged"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!--<Button Content="Сброс" Width="80" Height="36" Margin="0,0,8,0" Click="Reset_Click"/>-->
                    <Button Content="Войти" Width="80" Height="36" Margin="0,0,8,0" x:Name="auth" Click="auth_Click"/>
                    <Button x:Name="Profile" Content="Профиль" Width="100" Height="36" Background="#6A1B9A" Foreground="White" 
                            Click="Profile_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ListBox x:Name="KinoList" Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" Background="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="KinoList_SelectionChanged">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="4" Margin="8"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="1" Padding="8" Margin="8" Background="White" Width="180">
                        <StackPanel HorizontalAlignment="Center">
                            <Image Height="120" Width="160" Source="{Binding Image}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding Title}" TextAlignment="Center" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="Рейтинг: " Foreground="#555"/>
                                <TextBlock Text="{Binding Rating}" FontWeight="Bold"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ReleaseDate}" Foreground="#777" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>