<Page x:Class="pr14.MovieDetail"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr14"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Детали фильма">

    <Grid Background="#1A1A1A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#252525" Margin="15" CornerRadius="15" BorderBrush="#333" BorderThickness="1">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Border CornerRadius="10" ClipToBounds="True" Background="#000" Margin="0,0,0,20">
                            <Image Source="{Binding Image}" Stretch="Uniform" HorizontalAlignment="Center" MaxHeight="450"/>
                        </Border>

                        <TextBlock Text="{Binding Title}" Foreground="Gold" FontSize="28" FontWeight="ExtraBold" TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <Border Background="#333" HorizontalAlignment="Left" Padding="10,5" CornerRadius="5" Margin="0,0,0,15">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Рейтинг: " Foreground="LightGray" FontSize="16"/>
                                <TextBlock Text="{Binding Rating}" Foreground="White" FontWeight="Bold" FontSize="16"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="О ФИЛЬМЕ" Foreground="Gold" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding Description}" Foreground="#CCCCCC" TextWrapping="Wrap" FontSize="15" LineHeight="22" TextAlignment="Justify"/>
                        <Border Height="60"/>
                    </StackPanel>
                </ScrollViewer>

                <Button Content="Назад" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="20" Width="120" Height="40" Click="Back_Click" Background="#444" Foreground="White" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="ВЫБЕРИТЕ СЕАНС" Foreground="White" FontSize="22" FontWeight="Light" HorizontalAlignment="Center" Margin="0,10,0,30"/>

            <ListBox x:Name="SessionsList" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionChanged="SessionsList_SelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#333" CornerRadius="12" Margin="0,0,0,12" Padding="20" x:Name="SessionBorder">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ВРЕМЯ" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding TimeStart, StringFormat=\{0:hh\\:mm\}}" FontSize="24" FontWeight="Bold" Foreground="Gold"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="40,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="ДАТА" FontSize="10" Foreground="Gray"/>
                                    <TextBlock Text="{Binding DateStart, StringFormat=dd MMMM yyyy}" FontSize="16" Foreground="White"/>
                                </StackPanel>

                                <Border Grid.Column="2" Background="#444" CornerRadius="8" Padding="15,5">
                                    <TextBlock Text="{Binding Price, StringFormat=' {0} ₽'}" FontSize="20" FontWeight="Bold" Foreground="LimeGreen" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Grid>
    </Grid>
</Page>