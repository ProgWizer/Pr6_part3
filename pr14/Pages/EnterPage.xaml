<Page x:Class="pr14.Pages.EnterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EnterPage">

    <Grid Background="Gray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <Button Content="Назад" HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="25" Margin="10" x:Name="Last" Click="Last_Click"/>
        <Button Content="Зарегестрироваться"  HorizontalAlignment="Left" VerticalAlignment="Top" Width="100" Height="20" x:Name="Auth2" Margin="673,28,0,0" Click="Auth_Click"/>


        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Вход" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <TextBlock Text="Логин" Height="30" Margin="0,0,0,15"  Padding="5,0"/>
            <TextBox x:Name="login" Height="30" VerticalContentAlignment="Center" Padding="5,0"/>
            <TextBlock Text="Пароль" Height="30" Margin="0,0,0,15"  Padding="5,0"/>
            <TextBox x:Name="password" Height="30" VerticalContentAlignment="Center" Padding="5,0" Margin="0,0,0,20"/>


            <Button Content="Войти" Height="35" Background="Black" Foreground="White" x:Name="Enter" Click="Enter_Click"/>
        </StackPanel>

    </Grid>
</Page>
