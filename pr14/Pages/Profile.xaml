<Page x:Class="pr14.Pages.Profile"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Profile">

    <Grid Background="#2F2F2F">
        <Button Content="На главную" Width="100" Height="30" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="15" x:Name="Main" Click="Main_Click"/>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">

            <TextBlock Text="ЛИЧНЫЙ КАБИНЕТ" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Логин:" Foreground="Wheat" Width="80" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Login}" Foreground="White"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <TextBlock Text="Пароль:" Foreground="WhiteSmoke" Width="80" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding Password}" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="Ваши билеты:" Foreground="Wheat" Margin="0,20,0,5"/>

            <ListBox x:Name="KinoList" Height="200" Background="#3D3D3D" Foreground="White" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="5">
                            <StackPanel>
                                <TextBlock Text="{Binding MovieTitle}" FontWeight="Bold" Foreground="Gold" FontSize="16"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Сеанс: " Foreground="LightGray"/>
                                    <TextBlock Text="{Binding Time, StringFormat=\{0:hh\\:mm\}}" Foreground="White" Margin="0,0,10,0"/>
                                    <TextBlock Text="Ряд: " Foreground="LightGray"/>
                                    <TextBlock Text="{Binding Row}" Foreground="White" Margin="0,0,10,0"/>
                                    <TextBlock Text="Место: " Foreground="LightGray"/>
                                    <TextBlock Text="{Binding Num}" Foreground="White"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </StackPanel>
    </Grid>
</Page>
