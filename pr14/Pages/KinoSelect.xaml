<Page x:Class="pr14.Pages.KinoSelect"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pr14.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="KinoSelect">

   
        <Grid Background="DarkGray">
        <Button HorizontalAlignment="Left" x:Name="Last" Content="Назад" Foreground="White" Width="50" Height="50" VerticalAlignment="Top" Background="BurlyWood" Click="Last_Click" />
        <TextBlock x:Name="NameKino" Foreground="White" VerticalAlignment="Top" HorizontalAlignment="Center"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="Black" Height="5" Width="400" Margin="0,0,0,50">
                    <TextBlock Text="ЭКРАН" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                </Border>

            <ListBox x:Name="SeatsList" Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="3" Columns="5"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Number}" Click="CheckBox_Click" Foreground="Snow"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </StackPanel>

        <Button Content="Сбросить все" Width="50" Height="50" x:Name="Reset" HorizontalAlignment="Right" VerticalAlignment="Top" Background="BurlyWood" Foreground="White" Click="Reset_Click" />

    </Grid>
    
</Page>
